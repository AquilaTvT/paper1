# Java backend mode: in-memory keeps phase 2 mock scheduler; redis sends tasks through Redis Stream.
MMVS_INFERENCE_MODE=redis
MMVS_REDIS_ENABLED=true
MMVS_REDIS_HOST=localhost
MMVS_REDIS_PORT=6379
MMVS_REDIS_DATABASE=0
MMVS_REDIS_TASK_STREAM=mmvs:tasks:requests
MMVS_REDIS_EVENT_STREAM=mmvs:tasks:events

# Python inference worker / FastAPI mock mode with Redis Stream enabled.
MMVS_RUN_MODE=mock
MMVS_REDIS_URL=redis://localhost:6379/0
MMVS_SAMPLE_FPS=1
MMVS_PATCH_TOKENS_PER_FRAME=196
MMVS_COMPRESSED_TOKENS_PER_FRAME=5

# Vue frontend mode: mock keeps browser-only demo; backend calls Java REST/SSE.
VITE_API_MODE=backend
VITE_API_BASE_URL=http://localhost:8080/api
